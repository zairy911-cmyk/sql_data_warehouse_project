create view _gold.dim_customers as
select
	row_number() over(order by ci.cst_id) as customer_key,
	ci.cst_id as customer_id,
	ci.cst_key as customer_reference,
	ci.cst_firstname as first_name,
	ci.cst_lastname as last_name,
	ce.bdate as birthdate,
	cl.cntry as country,
	case
		when ci.cst_gndr != 'N/A' then ci.cst_gndr
		else coalesce(ce.gen, 'N/A')
	end as gender,
	ci.cst_marital_status as marital_status,
	ci.cst_create_date as create_date
from _silver.crm_cust_info as ci
left join _silver.erp_cust as ce
on ci.cst_key=ce.cid
left join _silver.erp_loc as cl
on ci.cst_key=cl.cid

create view _gold.dim_products as
select
	row_number() over(order by pi.prd_start_dt, pi.prd_key) as [p_key],
	pi.prd_id as product_id,
	pi.prd_key as product_key,
	pi.prd_key_short as product_key_short,
	pi.prd_nm as product_name,
	pi.prd_cat as product_category_short,
	px.cat as product_category,
	px.subcat as product_subcategory,
	pi.prd_line as product_line,
	pi.prd_cost as product_cost,
	px.maintenance as product_maintenance,
	pi.prd_start_dt as product_start_date,
	pi.prd_end_dt as product_end_date	
from [_silver].[crm_prd_info] as [pi]
left join [_silver].[erp_px_cat] as [px]
on pi.prd_cat=px.id
where pi.prd_end_dt is null

create view _gold.fact_sales as	
select
	ft.sls_ord_num as order_number, 
	pr.p_key as product_key,
	cu.customer_key as customer_key,
	ft.sls_order_dt as order_date,
	ft.sls_ship_dt as shipping_date,
	ft.sls_due_dt as due_date,
	ft.sls_sales as sales,
	ft.sls_quantity as quantity,
	ft.sls_price as price
from _silver.crm_sales_details as ft
inner join _gold.dim_products as pr
on ft.sls_prd_key=pr.product_key_short
inner join _gold.dim_customers as cu
on ft.sls_cust_id=cu.customer_id
